DATABASE_URL=sqlite:///./reelenglish.db
# PostgreSQL: postgresql://admin:securepass@localhost/reelenglish

# JWT 密钥（生产环境请修改为随机字符串）
SECRET_KEY=change-this-to-a-random-secret-key-in-production

OPENAI_API_KEY=your_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 科大讯飞语音评测
XF_APPID=your_appid
XF_API_KEY=your_api_key
XF_API_SECRET=your_api_secret

# 阿里云 OSS
OSS_ACCESS_KEY=your_oss_key
OSS_SECRET_KEY=your_oss_secret
OSS_BUCKET=reelenglish-audio
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# LangSmith 监控
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=RealEnglish
